###############################################################################
# Auto detect text files and normalize line endings to CRLF
###############################################################################
* text=auto eol=crlf

###############################################################################
# Explicitly declare text files
###############################################################################
*.cs      text diff=csharp
*.csproj  text
*.sln     text
*.resx    text
*.settings text
*.tt      text
*.txt     text
*.xml     text
*.json    text
*.md      text
*.editorconfig text

###############################################################################
# Explicitly declare binary files
###############################################################################
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.pdf     binary
*.zip     binary
*.nupkg   binary
*.snupkg  binary
*.dll     binary
*.exe     binary
*.pdb     binary
*.obj     binary
*.pch     binary
*.lib     binary
*.exp     binary
*.ilk     binary
*.meta    binary

###############################################################################
# Git LFS (if needed)
###############################################################################
# *.psd filter=lfs diff=lfs merge=lfs -text

###############################################################################
# Merge drivers
###############################################################################
*.csproj merge=union
*.sln    merge=union
*.json   merge=union

###############################################################################
# End of line for shell scripts (LF)
###############################################################################
*.sh      text eol=lf
*.bash    text eol=lf
*.ps1     text eol=crlf
